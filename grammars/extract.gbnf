root ::= "{\"steps\":[" step ("," step)* "]}"

step ::= read-step | write-step | shell-step

read-step ::= "{\"tool\":\"read\",\"args\":{\"path\":" string "}}"

write-step ::= "{\"tool\":\"write\",\"args\":{\"path\":" string ",\"content\":" string "}}"

shell-step ::= "{\"tool\":\"shell\",\"args\":{\"cmd\":" string "}}"

string ::= "\"" chars "\""

chars ::= char*

char ::= [^"\\] | "\\" escape

escape ::= ["\\nrt/]
